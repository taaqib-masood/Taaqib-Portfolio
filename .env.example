# ──────────────────────────────────────────────────────────
# REQUIRED: Groq API key for the LLaMA 3.3-70b agent
# Get yours at: https://console.groq.com/keys
# ──────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ──────────────────────────────────────────────────────────
# OPTIONAL: Resend API key for the contact form
# Get yours at: https://resend.com/api-keys
# Without this, form submissions are logged to console only.
# ──────────────────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here

# ──────────────────────────────────────────────────────────
# OPTIONAL: GitHub personal access token
# Increases rate limits for get_github_stats tool.
# Without this, the tool uses a cached fallback (569 contributions, 6 repos, 58 stars).
# ──────────────────────────────────────────────────────────
GITHUB_TOKEN=optional_for_higher_rate_limits
